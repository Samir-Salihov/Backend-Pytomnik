DJANGO_ENV=development
DJANGO_SETTINGS_MODULE=core.settings.dev
DEBUG=True
SECRET_KEY=django-insecure-dev-key
ALLOWED_HOSTS=localhost,127.0.0.1,web

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
