# ===== Django Settings =====
DEBUG=False
# SECRET_KEY with no special characters to avoid Docker expansion issues
SECRET_KEY=django-insecure-prod-key-no-special-chars-1234567890


# Allowed hosts (разделены запятыми)
ALLOWED_HOSTS=al-pytomnic.ru,www.al-pytomnic.ru,localhost,127.0.0.1,web

# Django environment
DJANGO_ENV=production
DJANGO_SETTINGS_MODULE=core.settings.prod

# ===== PostgreSQL Database =====
# Используйте имя контейнера (db) как POSTGRES_HOST в Docker
POSTGRES_DB=pytomnic
POSTGRES_USER=pytomnic_user
POSTGRES_PASSWORD=pytomnic123
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ===== Redis Cache & Celery =====
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ===== Email Configuration (для отправки писем) =====
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-not-real-password

# ===== AWS S3 (если используешь для медиа) =====
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=eu-west-1

# ===== Logging =====
LOG_LEVEL=INFO

# ===== Features =====
ENABLE_ANALYTICS=True
ENABLE_SEARCH=True
ENABLE_DEBUG_TOOLBAR=False

# ===== Sentry (для мониторинга ошибок) =====
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
